generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Hamster {
  id              String           @id @default(cuid())
  // 画面上ではハムスター名を識別子として扱うため、同名登録を避ける。
  name            String           @unique
  memo            String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  cleaningRecords CleaningRecord[]
  weightRecords   WeightRecord[]

  @@map("hamsters")
}

model CleaningRecord {
  id                   String   @id @default(cuid())
  hamsterId            String
  hamster              Hamster  @relation(fields: [hamsterId], references: [id], onDelete: Cascade)
  recordDate           DateTime @db.Date
  toiletCleaned        Boolean  @default(false)
  bathCleaned          Boolean  @default(false)
  flooringPartCleaned  Boolean  @default(false)
  flooringAllCleaned   Boolean  @default(false)
  houseCleaned         Boolean  @default(false)
  memo                 String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // 衛生管理表はハムスターごとに1日1行として保存する。
  @@unique([hamsterId, recordDate])
  @@index([recordDate])
  @@map("cleaning_records")
}

model WeightRecord {
  id         String   @id @default(cuid())
  hamsterId  String
  hamster    Hamster  @relation(fields: [hamsterId], references: [id], onDelete: Cascade)
  recordDate DateTime @db.Date
  weightG    Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // 体重履歴はハムスターごとに1日1件として保存する。
  @@unique([hamsterId, recordDate])
  @@index([recordDate])
  @@map("weight_records")
}

