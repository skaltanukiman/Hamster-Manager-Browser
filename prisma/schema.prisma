generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Hamster {
  id              String           @id @default(cuid())
  householdId     String?          @map("household_id")
  household       Household?       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  // ハムスター名は家庭内だけで重複を避け、別家庭なら同名を許可する。
  name            String
  memo            String?
  // カード表示にはまだ使わず、プロフィール情報として保存しておく日付。
  birthDate       DateTime?        @db.Date
  adoptionDate    DateTime?        @db.Date
  // 管理外にしたハムスターは記録編集をロックし、復活時に同じ履歴を再利用する。
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  cleaningRecords CleaningRecord[]
  weightRecords   WeightRecord[]
  dashboardEntries DashboardHamster[]

  @@unique([householdId, name])
  @@index([householdId])
  @@map("hamsters")
}

model CleaningRecord {
  id                   String   @id @default(cuid())
  hamsterId            String
  hamster              Hamster  @relation(fields: [hamsterId], references: [id], onDelete: Cascade)
  recordDate           DateTime @db.Date
  toiletCleaned        Boolean  @default(false)
  bathCleaned          Boolean  @default(false)
  flooringPartCleaned  Boolean  @default(false)
  flooringAllCleaned   Boolean  @default(false)
  houseCleaned         Boolean  @default(false)
  memo                 String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // 衛生管理表はハムスターごとに1日1行として保存する。
  @@unique([hamsterId, recordDate])
  @@index([recordDate])
  @@map("cleaning_records")
}

model WeightRecord {
  id         String   @id @default(cuid())
  hamsterId  String
  hamster    Hamster  @relation(fields: [hamsterId], references: [id], onDelete: Cascade)
  recordDate DateTime @db.Date
  weightG    Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // 体重履歴はハムスターごとに1日1件として保存する。
  @@unique([hamsterId, recordDate])
  @@index([recordDate])
  @@map("weight_records")
}

model AppSetting {
  id                  String             @id @default(cuid())
  userId              String?            @map("user_id")
  householdId         String?            @map("household_id")
  user                User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  household           Household?         @relation(fields: [householdId], references: [id], onDelete: Cascade)
  dashboardBoardCount Int                @default(6)
  // ハムスター選択UIを、検索入力できるコンボボックス式か従来のプルダウン式かで切り替える。
  hamsterSelectorMode String             @default("combobox")
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  dashboardHamsters   DashboardHamster[]

  @@unique([userId, householdId])
  @@map("app_settings")
}

model DashboardHamster {
  id        String     @id @default(cuid())
  settingId String
  setting   AppSetting @relation(fields: [settingId], references: [id], onDelete: Cascade)
  hamsterId String
  hamster   Hamster    @relation(fields: [hamsterId], references: [id], onDelete: Cascade)
  // 設定画面で選ばれた順序を保持し、ダッシュボード表示の優先順に使う。
  sortOrder Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([settingId, hamsterId])
  @@index([hamsterId])
  @@map("dashboard_hamsters")
}

model User {
  id            String            @id @default(cuid())
  name          String?
  email         String?           @unique
  emailVerified DateTime?         @map("email_verified")
  image         String?
  appRole       AppRole           @default(USER) @map("app_role")
  accounts      Account[]
  sessions      Session[]
  memberships   HouseholdMember[]
  appSettings   AppSetting[]
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Household {
  id          String                  @id @default(cuid())
  name        String
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")
  members     HouseholdMember[]
  hamsters    Hamster[]
  appSettings AppSetting[]
  invitations HouseholdInvitation[]

  @@map("households")
}

model HouseholdMember {
  id          String        @id @default(cuid())
  householdId String        @map("household_id")
  userId      String        @map("user_id")
  role        HouseholdRole @default(MEMBER)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([householdId, userId])
  @@index([userId])
  @@map("household_members")
}

model HouseholdInvitation {
  id          String     @id @default(cuid())
  householdId String     @map("household_id")
  tokenHash   String     @unique @map("token_hash")
  expiresAt   DateTime   @map("expires_at")
  acceptedAt  DateTime?  @map("accepted_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  household   Household  @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId])
  @@map("household_invitations")
}

enum HouseholdRole {
  OWNER
  ADMIN
  MEMBER
}

enum AppRole {
  USER
  ADMIN
  SUPER_ADMIN
}
