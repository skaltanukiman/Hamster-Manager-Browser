{
  "name": "hamster-manager-browser",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "tsx --test \"tests/**/*.test.ts\" \"tests/**/*.test.tsx\"",
    "log:smoke": "tsx scripts/log-smoke.ts",
    "invitations:cleanup": "tsx scripts/cleanup-invitations.ts",
    "household-activities:cleanup": "tsx scripts/cleanup-household-activities.ts",
    "admin:grant": "tsx prisma/admin-role.ts",
    "admin:revoke": "tsx prisma/admin-role.ts --role USER",
    "migrate:assign-owner": "tsx prisma/assign-owner.ts",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:seed": "prisma db seed",
    "seed:admin-pagination": "tsx prisma/seed-admin-pagination.ts",
    "seed:hamster-pagination": "tsx prisma/seed-hamster-pagination.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.1.0",
    "lucide-react": "^0.468.0",
    "next": "^16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.0",
    "sharp": "^0.34.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "postcss": "8.5.15",
    "prisma": "^6.1.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
